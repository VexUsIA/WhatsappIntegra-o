# Configurações do Serviço
NODE_ENV=development
PORT=3000

# JWT Secret (MUDE EM PRODUÇÃO!)
JWT_SECRET=change-this-secret-in-production-use-random-string

# PostgreSQL do SCOM (para ler fila)
SCOM_DB_HOST=localhost
SCOM_DB_PORT=5432
SCOM_DB_NAME=scom_db
SCOM_DB_USER=scom_user
SCOM_DB_PASSWORD=scom_password

# PostgreSQL do Serviço (para sessões e logs)
SERVICE_DB_HOST=localhost
SERVICE_DB_PORT=5432
SERVICE_DB_NAME=whatsapp_service
SERVICE_DB_USER=whatsapp_user
SERVICE_DB_PASSWORD=whatsapp_password
DATABASE_URL="postgresql://${SERVICE_DB_USER}:${SERVICE_DB_PASSWORD}@${SERVICE_DB_HOST}:${SERVICE_DB_PORT}/${SERVICE_DB_NAME}?schema=public"

# Redis (para filas BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Configurações de Polling
POLLING_INTERVAL_MS=2000

# Configurações de Retry
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_MS=5000

# Configurações de Health Check
HEALTH_CHECK_INTERVAL_MS=30000

# Logs
LOG_LEVEL=info
LOG_DIR=./logs
